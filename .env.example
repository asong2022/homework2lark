# FastAPI
APP_ENV=development
DATABASE_URL=sqlite:///../../data/mistake-notebook.db
STORAGE_ROOT=../../storage
MAX_UPLOAD_BYTES=15728640
MAX_IMAGE_PIXELS=40000000
MIN_REGION_PIXELS=4
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# OCR: paddleocr_vl_api (official hosted API, default) or paddleocr (local)
OCR_PROVIDER=paddleocr_vl_api
OCR_TIMEOUT_SECONDS=120
PADDLEOCR_LANGUAGE=ch
PADDLEOCR_MODEL_NAME=PP-OCRv5_server_rec
PADDLEOCR_ACCESS_TOKEN=
PADDLEOCR_API_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_VL_MODEL=PaddleOCR-VL-1.6
PADDLEOCR_API_REQUEST_TIMEOUT_SECONDS=30
PADDLEOCR_API_POLL_INTERVAL_SECONDS=5

# Question boxes: manual (default, teacher draws/selects) or yescan
REGION_DETECTION_PROVIDER=manual

# Yescan standard API (BACK_ credentials; never use the AI Agent key here)
YESCAN_API_KEY_ID=
YESCAN_API_KEY=
YESCAN_API_BASE_URL=https://scan-business.quark.cn/vision
YESCAN_TIMEOUT_SECONDS=120

# Problem publication: real Feishu user identity through lark_cli
PROBLEM_PUBLISHER=lark_cli
LARK_BASE_TITLE=小学数学错题学习库
LARK_CLI_COMMAND=lark-cli
LARK_PUBLISH_TIMEOUT_SECONDS=120

# Next.js (copy this line to apps/web/.env.local when overriding)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
